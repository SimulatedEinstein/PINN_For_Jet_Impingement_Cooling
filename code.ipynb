# ============================================================
# PINN: Jet-embedded Uniform Inflow Impinging on a Cylinder
# Re = 2000, Pr = 0.71, H/D = 2 (inlet plane to cylinder front)
# - Uniform background flow U_inf
# - Gaussian jet bump superimposed on U_inf at inlet (x = -Lx)
# - Isothermal cylinder wall (T_wall)
# - Outputs:
#     1) Clean velocity & temperature contours
#     2) Local Nusselt-number distribution Nu(θ)
#     3) Stagnation Nusselt at the jet impact point
# ============================================================

import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from torch.autograd import grad
import matplotlib.pyplot as plt

# ---------------- Device ----------------
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Using device: {device}")

# ---------------- Physical params (non-dimensional) ----------------
Re   = 2000.0
Pr   = 0.71
D    = 1.0                      # cylinder diameter (reference length)
Uinf = 0.6                      # uniform inflow component (background stream)
Uref = 1.0                      # reference velocity for Re; we keep Uref=1 for nu definition
nu   = Uref * D / Re            # kinematic viscosity used in PDE
alpha = nu / Pr                 # thermal diffusivity

# Thermal settings
T_wall = 0.0                    # cylinder surface temperature (isothermal)
T_inf  = 0.0                    # ambient/background inflow temperature
T_jet  = 1.0                    # jet fluid temperature

# ---------------- Domain & geometry ----------------
Lx = 5.0 * D                    # half-domain length for plotting; inlet is at x = -Lx
Ly = 2.5 * D                    # half-domain height

# Enforce H/D = 2 between inlet plane (x = -Lx) and the cylinder *front face*
H_over_D = 2.0
H = H_over_D * D
R  = 0.5 * D
xc = -Lx + H + R                # cylinder center x so that (-Lx) -> (xc-R) = H
yc = 0.0

# ---------------- Jet profile at inlet (superimposed on U_inf) ----------------
jet_center_y = 0.0
jet_width    = 0.5 * D          # Gaussian width ~ jet radius
U_jet_max    = 2.0              # peak jet speed (so inlet u = Uinf + gaussian up to U_jet_max)

def gaussian(y, y0, w):
    return np.exp(-0.5 * ((y - y0)/w)**2)

def inlet_u_profile(y_arr):
    # Background + jet bump (capped so it doesn't exceed U_jet_max)
    bump = (U_jet_max - Uinf) * gaussian(y_arr, jet_center_y, jet_width)
    return Uinf + bump

def inlet_T_profile(y_arr):
    # Jet hotter than ambient: T = T_inf + (T_jet - T_inf)*bump_norm
    bump = gaussian(y_arr, jet_center_y, jet_width)
    return T_inf + (T_jet - T_inf) * bump

# ---------------- PINN ----------------
class CylinderPINN(nn.Module):
    def __init__(self, layers):
        super().__init__()
        self.layers = nn.ModuleList([nn.Linear(layers[i], layers[i+1])
                                     for i in range(len(layers)-1)])
        for layer in self.layers:
            nn.init.xavier_normal_(layer.weight)
            nn.init.zeros_(layer.bias)

    def forward(self, x, y):
        z = torch.cat([x, y], dim=1)
        for layer in self.layers[:-1]:
            z = torch.tanh(layer(z))
        z = self.layers[-1](z)
        u = z[:, 0:1]           # x-velocity
        v = z[:, 1:2]           # y-velocity
        p = z[:, 2:3]
        T = z[:, 3:4]
        return u, v, p, T

def d(outputs, inputs):
    return grad(outputs, inputs, grad_outputs=torch.ones_like(outputs),
                create_graph=True, retain_graph=True)[0]

# ---------------- Residuals ----------------
def physics_residuals(model, x, y):
    x.requires_grad_(True)
    y.requires_grad_(True)
    u, v, p, T = model(x, y)

    u_x = d(u, x); u_y = d(u, y)
    v_x = d(v, x); v_y = d(v, y)
    p_x = d(p, x); p_y = d(p, y)
    T_x = d(T, x); T_y = d(T, y)

    u_xx = d(u_x, x); u_yy = d(u_y, y)
    v_xx = d(v_x, x); v_yy = d(v_y, y)
    T_xx = d(T_x, x); T_yy = d(T_y, y)

    cont   = u_x + v_y
    mom_x  = u*u_x + v*u_y + p_x - nu*(u_xx + u_yy)
    mom_y  = u*v_x + v*v_y + p_y - nu*(v_xx + v_yy)
    energy = u*T_x + v*T_y - alpha*(T_xx + T_yy)
    return cont, mom_x, mom_y, energy

# ---------------- Sampling ----------------
def collocation_points(N):
    x = np.random.uniform(-Lx, Lx, N*2)
    y = np.random.uniform(-Ly, Ly, N*2)
    mask_outside = (x - xc)**2 + (y - yc)**2 >= R**2 + 1e-12
    x = x[mask_outside][:N]; y = y[mask_outside][:N]
    return (torch.tensor(x[:,None], dtype=torch.float32, device=device),
            torch.tensor(y[:,None], dtype=torch.float32, device=device))

def boundary_points(N):
    bc = {}

    # Cylinder wall: no-slip + isothermal
    theta = np.random.uniform(0, 2*np.pi, N)
    xw = xc + R*np.cos(theta)
    yw = yc + R*np.sin(theta)
    bc['cylinder'] = {
        'x': torch.tensor(xw[:,None], dtype=torch.float32, device=device),
        'y': torch.tensor(yw[:,None], dtype=torch.float32, device=device),
        'vals': {'u': torch.zeros((N,1), device=device),
                 'v': torch.zeros((N,1), device=device),
                 'T': torch.full((N,1), float(T_wall), device=device)}
    }

    # Inlet at x = -Lx: u = Uinf + jet bump, v = 0, T = profile
    y_in = np.random.uniform(-Ly, Ly, N)
    x_in = -Lx * np.ones_like(y_in)
    u_in = inlet_u_profile(y_in)
    T_in = inlet_T_profile(y_in)
    bc['inlet'] = {
        'x': torch.tensor(x_in[:,None], dtype=torch.float32, device=device),
        'y': torch.tensor(y_in[:,None], dtype=torch.float32, device=device),
        'vals': {'u': torch.tensor(u_in[:,None], dtype=torch.float32, device=device),
                 'v': torch.zeros((N,1), device=device),
                 'T': torch.tensor(T_in[:,None], dtype=torch.float32, device=device)}
    }

    # Outlet at x = +Lx: set pressure to zero (do not constrain u,v)
    y_out = np.random.uniform(-Ly, Ly, N)
    x_out = Lx * np.ones_like(y_out)
    bc['outlet'] = {
        'x': torch.tensor(x_out[:,None], dtype=torch.float32, device=device),
        'y': torch.tensor(y_out[:,None], dtype=torch.float32, device=device),
        'vals': {'p': torch.zeros((N,1), device=device)}
    }

    # Top and bottom: weak confinement -> v=0, T=T_inf
    x_tb = np.random.uniform(-Lx, Lx, N)
    bc['top'] = {
        'x': torch.tensor(x_tb[:,None], dtype=torch.float32, device=device),
        'y': torch.tensor((Ly*np.ones(N))[:,None], dtype=torch.float32, device=device),
        'vals': {'v': torch.zeros((N,1), device=device),
                 'T': torch.full((N,1), float(T_inf), device=device)}
    }
    bc['bottom'] = {
        'x': torch.tensor(x_tb[:,None], dtype=torch.float32, device=device),
        'y': torch.tensor((-Ly*np.ones(N))[:,None], dtype=torch.float32, device=device),
        'vals': {'v': torch.zeros((N,1), device=device),
                 'T': torch.full((N,1), float(T_inf), device=device)}
    }

    return bc

def boundary_loss(model, x_bc, y_bc, bc_vals):
    u_pred, v_pred, p_pred, T_pred = model(x_bc, y_bc)
    loss = 0.0
    for key, val in bc_vals.items():
        if key == 'u': loss += torch.mean((u_pred - val)**2)
        if key == 'v': loss += torch.mean((v_pred - val)**2)
        if key == 'p': loss += torch.mean((p_pred - val)**2)
        if key == 'T': loss += torch.mean((T_pred - val)**2)
    return loss

# ---------------- Training ----------------
def train(model, epochs=50000, Nf=7000, Nb=1200, lr=1e-3,
          lam_pde=1.0, lam_bc=300.0, print_every=10000):
    opt = optim.Adam(model.parameters(), lr=lr)
    for ep in range(epochs):
        x_f, y_f = collocation_points(Nf)
        bc = boundary_points(Nb)

        opt.zero_grad()
        cont, mx, my, energy = physics_residuals(model, x_f, y_f)
        loss_pde = (cont**2 + mx**2 + my**2 + energy**2).mean()
        loss_bc = sum(boundary_loss(model, v['x'], v['y'], v['vals']) for v in bc.values())
        loss = lam_pde*loss_pde + lam_bc*loss_bc
        loss.backward()
        opt.step()

        if ep % print_every == 0:
            print(f"Epoch {ep:5d}: total={loss.item():.3e}  PDE={loss_pde.item():.3e}  BC={loss_bc.item():.3e}")

    # Polishing with L-BFGS
    def closure():
        opt_lbfgs.zero_grad()
        x_f, y_f = collocation_points(Nf)
        bc = boundary_points(Nb)
        cont, mx, my, energy = physics_residuals(model, x_f, y_f)
        loss_pde = (cont**2 + mx**2 + my**2 + energy**2).mean()
        loss_bc = sum(boundary_loss(model, v['x'], v['y'], v['vals']) for v in bc.values())
        loss = lam_pde*loss_pde + lam_bc*loss_bc
        loss.backward()
        return loss

    print("Starting L-BFGS refinement...")
    opt_lbfgs = optim.LBFGS(model.parameters(), lr=1.0, max_iter=200,
                            tolerance_grad=1e-7, tolerance_change=1e-9)
    opt_lbfgs.step(closure)
    print("Training complete.")

# ---------------- Nusselt ----------------
# Convention: outward normal into the fluid; with cold wall & hotter jet,
# Nu = [ - (∂T/∂n) ] * D / (T_wall - T_ref). We take T_ref = T_jet (peak).
def stagnation_nusselt(model):
    # leftmost point (jet strikes here)
    x_s = torch.tensor([[xc - R]], dtype=torch.float32, device=device, requires_grad=True)
    y_s = torch.tensor([[yc     ]], dtype=torch.float32, device=device, requires_grad=True)
    _, _, _, T_s = model(x_s, y_s)
    T_x = d(T_s, x_s)                  # normal = (-1, 0) → dT/dn = -T_x
    dTdn = -T_x
    Nu0 = (-dTdn) * D / (T_wall - T_jet)
    return float(Nu0.detach().cpu().numpy())

def nusselt_distribution(model, n_points=360):
    theta = np.linspace(0, 2*np.pi, n_points, endpoint=False)
    xw = xc + R*np.cos(theta);  yw = yc + R*np.sin(theta)
    x_t = torch.tensor(xw[:,None], dtype=torch.float32, device=device, requires_grad=True)
    y_t = torch.tensor(yw[:,None], dtype=torch.float32, device=device, requires_grad=True)
    _, _, _, T_pred = model(x_t, y_t)
    T_x = d(T_pred, x_t)
    T_y = d(T_pred, y_t)
    nx = torch.tensor(np.cos(theta)[:,None], dtype=torch.float32, device=device)
    ny = torch.tensor(np.sin(theta)[:,None], dtype=torch.float32, device=device)
    dTdn = T_x*nx + T_y*ny
    Nu = (-dTdn) * D / (T_wall - T_jet)
    return np.degrees(theta), Nu.detach().cpu().numpy().flatten()

# ---------------- Visualization ----------------
def plot_fields(model):
    nx, ny = 220, 200
    X = np.linspace(-Lx, Lx, nx)
    Y = np.linspace(-Ly, Ly, ny)
    XX, YY = np.meshgrid(X, Y)
    x_t = torch.tensor(XX.reshape(-1,1), dtype=torch.float32, device=device)
    y_t = torch.tensor(YY.reshape(-1,1), dtype=torch.float32, device=device)
    with torch.no_grad():
        u, v, p, T = model(x_t, y_t)
    U = u.cpu().numpy().reshape(YY.shape)
    V = v.cpu().numpy().reshape(YY.shape)
    Tn = T.cpu().numpy().reshape(YY.shape)
    Mag = np.sqrt(U**2 + V**2)

    mask = (XX - xc)**2 + (YY - yc)**2 <= R**2
    Mag = np.where(mask, np.nan, Mag)
    Tn  = np.where(mask, np.nan, Tn)

    fig, axs = plt.subplots(1, 2, figsize=(12,5))
    c1 = axs[0].contourf(XX, YY, Mag, 80, cmap='viridis')
    axs[0].add_patch(plt.Circle((xc, yc), R, color='white'))
    axs[0].set_title('Velocity Magnitude over Cylinder')
    axs[0].set_xlabel('x'); axs[0].set_ylabel('y')
    fig.colorbar(c1, ax=axs[0], label='|Velocity|')

    c2 = axs[1].contourf(XX, YY, Tn, 80, cmap='inferno')
    axs[1].add_patch(plt.Circle((xc, yc), R, color='white'))
    axs[1].set_title('Temperature Field')
    axs[1].set_xlabel('x'); axs[1].set_ylabel('y')
    fig.colorbar(c2, ax=axs[1], label='T')

    plt.tight_layout(); plt.show()

def plot_nusselt(theta_deg, Nu):
    plt.figure(figsize=(8,4))
    plt.plot(theta_deg, Nu, lw=2)
    plt.xlabel('θ (deg)   [180° = left stagnation]')
    plt.ylabel('Local Nusselt number')
    plt.title('Nusselt Number Distribution on Cylinder')
    plt.grid(True)
    plt.tight_layout()
    plt.show()

# ---------------- Main ----------------
if __name__ == "__main__":
    layers = [2, 128, 128, 128, 128, 4]   # balanced capacity
    model = CylinderPINN(layers).to(device)

    # Optional: visualize inlet shape before training
    y_test = np.linspace(-Ly, Ly, 400)
    plt.figure()
    plt.plot(inlet_u_profile(y_test), y_test, label='u_in(y)')
    plt.plot(inlet_T_profile(y_test), y_test, label='T_in(y)')
    plt.legend(); plt.xlabel('Value'); plt.ylabel('y')
    plt.title('Inlet Profiles (u and T)'); plt.grid(True); plt.show()

    # Train
    train(model, epochs=50000, Nf=7000, Nb=1200, lr=1e-3, lam_bc=300.0)

    # Contours
    plot_fields(model)

    # Nusselt distribution + stagnation Nusselt
    theta_deg, Nu = nusselt_distribution(model, n_points=360)
    Nu0 = stagnation_nusselt(model)
    print(f"\nStagnation Nusselt (H/D=2, jet-embedded inflow): Nu0 = {Nu0:.3f}")
    print(f"Local Nu range: min={Nu.min():.3f}, max={Nu.max():.3f}")

    plot_nusselt(theta_deg, Nu)
